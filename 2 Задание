import random

numbers = [[random.randint(1, 10) for j in range(4)] for i in range(3)]

print("Список:")
for row in numbers:
    print(row)

total_sum = 0
max_row_sum = 0
max_row_index = 0

for i in range(len(numbers)):
    row_sum = 0
    for j in range(len(numbers[i])):
        row_sum += numbers[i][j]

    print(f"Сумма строки {i}: {row_sum}")
    total_sum += row_sum

    if row_sum > max_row_sum:
        max_row_sum = row_sum
        max_row_index = i

print(f"\nОбщая сумма: {total_sum}")
print(f"Строка с максимальной суммой: {max_row_index} (сумма = {max_row_sum})")
